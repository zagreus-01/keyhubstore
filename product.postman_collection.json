            ],
            "url": {
              "raw": "http://localhost:8080/api/product/:id",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "product", ":id"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productName\": \"Updated Product Name\"\n}"
            }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "http://localhost:8080/api/product/:id",
