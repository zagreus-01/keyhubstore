{
  "info": {
    "_postman_id": "product-module",
    "name": "Product - Brand - Category API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "CATEGORY",
      "item": [
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "http://localhost:8080/api/category",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "category"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Phone\",\n  \"slug\": \"phone\",\n  \"description\": \"Smart phone category\"\n}"
            }
          }
        },
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8080/api/category",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "category"]
            }
          }
        }
      ]
    },

    {
