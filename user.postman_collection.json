{
  "info": {
    "name": "User Module API",
    "_postman_id": "user-module-001",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Profile",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/user/profile",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "user", "profile"]
            }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Nguyen Van A\",\n  \"phone\": \"0123456789\",\n  \"avatar\": \"https://img.com/avatar.png\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/user/profile",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "user", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "Change Password",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"oldPassword\": \"123456\",\n  \"newPassword\": \"12345678\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/user/change-password",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "user", "change-password"]
        }
      }
    },
    {
      "name": "Address",
      "item": [
        {
          "name": "Add Address",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Nguyen Van A\",\n  \"phone\": \"0123456789\",\n  \"province\": \"Quang Ngai\",\n  \"district\": \"TP Quang Ngai\",\n  \"ward\": \"Ward 1\",\n  \"detailAddress\": \"123 ABC Street\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/user/address",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "user", "address"]
            }
          }
        },
        {
          "name": "Get Addresses",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/user/address",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "user", "address"]
            }
          }
        },
        {
          "name": "Update Address",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"province\": \"Da Nang\",\n  \"district\": \"Hai Chau\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/user/address/{{addressId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "user", "address", "{{addressId}}"]
            }
          }
        },
        {
          "name": "Delete Address",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/user/address/{{addressId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "user", "address", "{{addressId}}"]
            }
          }
        },
        {
          "name": "Set Default Address",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/user/address/default/{{addressId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "user", "address", "default", "{{addressId}}"]
